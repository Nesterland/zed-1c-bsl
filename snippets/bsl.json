{
  "Procedure full": {
    "prefix": "процедура",
    "body": [
      "Процедура ${1:ИмяПроцедуры}(${2:Параметры})",
      "\t$0",
      "КонецПроцедуры"
    ],
    "description": "Создать процедуру BSL (полное слово)"
  },
  "Procedure": {
    "prefix": "proc",
    "body": [
      "Процедура ${1:ИмяПроцедуры}(${2:Параметры})",
      "\t$0",
      "КонецПроцедуры"
    ],
    "description": "Создать процедуру BSL"
  },
  "Procedure RU": {
    "prefix": "проц",
    "body": [
      "Процедура ${1:ИмяПроцедуры}(${2:Параметры})",
      "\t$0",
      "КонецПроцедуры"
    ],
    "description": "Создать процедуру BSL (RU)"
  },
  "Procedure with Header": {
    "prefix": "proch",
    "body": [
      "// <Описание процедуры>",
      "//",
      "// Параметры:",
      "//  ${2:Параметр1}  - <Тип> - <описание>",
      "//",
      "Процедура ${1:ИмяПроцедуры}(${2:Параметр1})",
      "\t$0",
      "КонецПроцедуры"
    ],
    "description": "Процедура с заголовком"
  },
  "Procedure Form Module": {
    "prefix": "procf",
    "body": [
      "&${1:НаКлиенте}",
      "Процедура ${2:ИмяПроцедуры}()",
      "\t$0",
      "КонецПроцедуры"
    ],
    "description": "Процедура модуля формы"
  },
  "Function full": {
    "prefix": "функция",
    "body": [
      "Функция ${1:ИмяФункции}(${2:Параметры})",
      "\t$0",
      "\tВозврат ${3:Результат};",
      "КонецФункции"
    ],
    "description": "Создать функцию BSL (полное слово)"
  },
  "Function": {
    "prefix": "func",
    "body": [
      "Функция ${1:ИмяФункции}(${2:Параметры})",
      "\t$0",
      "\tВозврат ${3:Результат};",
      "КонецФункции"
    ],
    "description": "Создать функцию BSL"
  },
  "Function RU": {
    "prefix": "функ",
    "body": [
      "Функция ${1:ИмяФункции}(${2:Параметры})",
      "\t$0",
      "\tВозврат ${3:Результат};",
      "КонецФункции"
    ],
    "description": "Создать функцию BSL (RU)"
  },
  "Function with Header": {
    "prefix": "funch",
    "body": [
      "// <Описание функции>",
      "//",
      "// Параметры:",
      "//  ${2:Параметр1}  - <Тип> - <описание>",
      "//",
      "// Возвращаемое значение:",
      "//   <Тип> - <описание>",
      "//",
      "Функция ${1:ИмяФункции}(${2:Параметр1})",
      "\t$0",
      "\tВозврат ${3:Результат};",
      "КонецФункции"
    ],
    "description": "Функция с заголовком"
  },
  "Function Form Module": {
    "prefix": "funcf",
    "body": [
      "&${1:НаКлиенте}",
      "Функция ${2:ИмяФункции}()",
      "\t$0",
      "\tВозврат ${3:Результат};",
      "КонецФункции"
    ],
    "description": "Функция модуля формы"
  },
  "If": {
    "prefix": "if",
    "body": ["Если ${1:Условие} Тогда", "\t$0", "КонецЕсли;"],
    "description": "Условие Если"
  },
  "If RU": {
    "prefix": "если",
    "body": ["Если ${1:Условие} Тогда", "\t$0", "КонецЕсли;"],
    "description": "Условие Если (RU)"
  },
  "If Else": {
    "prefix": "ife",
    "body": [
      "Если ${1:Условие} Тогда",
      "\t${2}",
      "Иначе",
      "\t$0",
      "КонецЕсли;"
    ],
    "description": "Условие Если / Иначе"
  },
  "If ElsIf": {
    "prefix": "ifei",
    "body": [
      "Если ${1:Условие1} Тогда",
      "\t${2}",
      "ИначеЕсли ${3:Условие2} Тогда",
      "\t$0",
      "КонецЕсли;"
    ],
    "description": "Условие Если / ИначеЕсли"
  },
  "For": {
    "prefix": "for",
    "body": [
      "Для ${1:Счетчик} = ${2:Начало} По ${3:Конец} Цикл",
      "\t$0",
      "КонецЦикла;"
    ],
    "description": "Цикл Для ... По"
  },
  "For Each": {
    "prefix": "foreach",
    "body": [
      "Для Каждого ${1:Элемент} Из ${2:Коллекция} Цикл",
      "\t$0",
      "КонецЦикла;"
    ],
    "description": "Цикл Для каждого"
  },
  "While": {
    "prefix": "while",
    "body": ["Пока ${1:Условие} Цикл", "\t$0", "КонецЦикла;"],
    "description": "Цикл Пока"
  },
  "Try Except": {
    "prefix": "try",
    "body": ["Попытка", "\t${1}", "Исключение", "\t$0", "КонецПопытки;"],
    "description": "Блок Попытка / Исключение"
  },
  "Return": {
    "prefix": "return",
    "body": ["Возврат ${1:Результат};"],
    "description": "Возврат с результатом"
  },
  "Region": {
    "prefix": "region",
    "body": ["#Область ${1:ИмяОбласти}", "$0", "#КонецОбласти"],
    "description": "Область кода"
  },
  "Preprocessor If": {
    "prefix": "preif",
    "body": ["#Если ${1:Условие} Тогда", "\t$0", "#КонецЕсли"],
    "description": "Инструкция #Если"
  },
  "Variable": {
    "prefix": "var",
    "body": ["Перем ${1:ИмяПеременной};"],
    "description": "Объявление переменной"
  },
  "New Structure": {
    "prefix": "struct",
    "body": ["Новый Структура(\"${1:Ключ1}\", ${2:Значение1})$0"],
    "description": "Создать структуру"
  },
  "New Match": {
    "prefix": "match",
    "body": ["Новый Соответствие$0"],
    "description": "Создать соответствие"
  },
  "New Array": {
    "prefix": "arr",
    "body": ["Новый Массив$0"],
    "description": "Создать массив"
  },
  "Message": {
    "prefix": "msg",
    "body": ["Сообщить(\"${1:Текст}\");"],
    "description": "Вывод сообщения"
  },
  "DoMessageBox": {
    "prefix": "msgbox",
    "body": ["Предупреждение(${1:Текст});"],
    "description": "Предупреждение"
  },
  "Type Check": {
    "prefix": "typecheck",
    "body": [
      "Если ТипЗнч(${1:Значение}) = Тип(\"${2:ИмяТипа}\") Тогда",
      "\t$0",
      "КонецЕсли;"
    ],
    "description": "Проверка типа"
  },
  "Format": {
    "prefix": "format",
    "body": ["Формат(${1:Значение}, \"${2:ФорматнаяСтрока}\")"],
    "description": "Форматирование значения"
  },
  "Empty Query": {
    "prefix": "query",
    "body": [
      "Запрос = Новый Запрос;",
      "Запрос.Текст = \"${1:ВЫБРАТЬ}",
      "\t|   ${2:Поля}",
      "\t|ИЗ",
      "\t|   ${3:Источник}\";",
      "$0"
    ],
    "description": "Создать заготовку запроса"
  },
  "Query Execute": {
    "prefix": "queryrun",
    "body": [
      "Запрос = Новый Запрос;",
      "Запрос.Текст = \"${1:ТекстЗапроса}\";",
      "Результат = Запрос.Выполнить();",
      "Выборка = Результат.Выбрать();",
      "Пока Выборка.Следующий() Цикл",
      "\t$0",
      "КонецЦикла;"
    ],
    "description": "Запрос с выполнением и обходом"
  },
  "Catalog Traversal": {
    "prefix": "catloop",
    "body": [
      "Выборка = Справочники.${1:ИмяСправочника}.Выбрать();",
      "Пока Выборка.Следующий() Цикл",
      "\t$0",
      "КонецЦикла;"
    ],
    "description": "Обход элементов справочника"
  },
  "Document Traversal": {
    "prefix": "docloop",
    "body": [
      "Выборка = Документы.${1:ИмяДокумента}.Выбрать();",
      "Пока Выборка.Следующий() Цикл",
      "\t$0",
      "КонецЦикла;"
    ],
    "description": "Обход документов"
  },
  "Info Register Traversal": {
    "prefix": "regloop",
    "body": [
      "Выборка = РегистрыСведений.${1:ИмяРегистра}.Выбрать();",
      "Пока Выборка.Следующий() Цикл",
      "\t$0",
      "КонецЦикла;"
    ],
    "description": "Обход записей регистра сведений"
  },
  "Open Form": {
    "prefix": "openform",
    "body": ["ОткрытьФорму(\"${1:ИмяФормы}\")"],
    "description": "Открыть форму"
  },
  "Open Form with Params": {
    "prefix": "openformp",
    "body": [
      "ПараметрыФормы = Новый Структура;",
      "ПараметрыФормы.Вставить(\"${1:Ключ}\", ${2:Значение});",
      "ОткрытьФорму(\"${3:ИмяФормы}\", ПараметрыФормы);",
      "$0"
    ],
    "description": "Открыть форму с параметрами"
  },
  "Get Constant": {
    "prefix": "constget",
    "body": ["Константы.${1:ИмяКонстанты}.Получить()"],
    "description": "Получить константу"
  },
  "Set Constant": {
    "prefix": "constset",
    "body": ["Константы.${1:ИмяКонстанты}.Установить(${2:Значение});"],
    "description": "Установить константу"
  },
  "Predefined Value": {
    "prefix": "predef",
    "body": ["ПредопределенноеЗначение(\"${1:Имя}\")"],
    "description": "Предопределенное значение"
  },
  "Get Functional Option": {
    "prefix": "funcopt",
    "body": ["ПолучитьФункциональнуюОпцию(\"${1:ИмяОпции}\")"],
    "description": "Получить функциональную опцию"
  },
  "User Message": {
    "prefix": "usermsg",
    "body": [
      "Сообщение = Новый СообщениеПользователю;",
      "Сообщение.Текст = \"${1:Текст}\";",
      "Сообщение.Поле = \"${2:ИмяПоля}\";",
      "Сообщение.УстановитьДанные(${3:Данные});",
      "Сообщение.Сообщить();"
    ],
    "description": "СообщениеПользователю"
  },
  "Transaction": {
    "prefix": "tran",
    "body": ["НачатьТранзакцию();", "${1:Код}", "ЗафиксироватьТранзакцию();"],
    "description": "Блок транзакции"
  },
  "Query Full": {
    "prefix": "запрос",
    "body": [
      "Запрос = Новый Запрос;",
      "Запрос.Текст =",
      "\t\"ВЫБРАТЬ",
      "\t|\t${1:Поле1} КАК Поле1",
      "\t|ИЗ",
      "\t|\t${2:Источник} КАК Источник\";",
      "",
      "РезультатЗапроса = Запрос.Выполнить();",
      "",
      "Если РезультатЗапроса.Пустой() Тогда",
      "\tВозврат;",
      "КонецЕсли;",
      "",
      "ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();",
      "",
      "Пока ВыборкаДетальныеЗаписи.Следующий() Цикл",
      "\t// Вставить обработку выборки ВыборкаДетальныеЗаписи",
      "\t$0",
      "КонецЦикла;"
    ],
    "description": "Полная конструкция запроса с обходом результата"
  },
  "Query with Params": {
    "prefix": "запросп",
    "body": [
      "Запрос = Новый Запрос;",
      "Запрос.Текст =",
      "\t\"ВЫБРАТЬ",
      "\t|\t${1:Поле1} КАК Поле1",
      "\t|ИЗ",
      "\t|\t${2:Источник} КАК Источник",
      "\t|ГДЕ",
      "\t|\tИсточник.Поле = &Параметр\";",
      "",
      "Запрос.УстановитьПараметр(\"Параметр\", ${3:ЗначениеПараметра});",
      "",
      "РезультатЗапроса = Запрос.Выполнить();",
      "",
      "ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();",
      "",
      "Пока ВыборкаДетальныеЗаписи.Следующий() Цикл",
      "\t// Вставить обработку выборки ВыборкаДетальныеЗаписи",
      "\t$0",
      "КонецЦикла;"
    ],
    "description": "Запрос с параметром и обходом результата"
  },
  "If full RU": {
    "prefix": "если",
    "body": ["Если ${1:Условие} Тогда", "\t$0", "КонецЕсли;"],
    "description": "Условие Если (полное слово)"
  },
  "For full RU": {
    "prefix": "для",
    "body": [
      "Для ${1:Счетчик} = ${2:Начало} По ${3:Конец} Цикл",
      "\t$0",
      "КонецЦикла;"
    ],
    "description": "Цикл Для ... По (полное слово)"
  },
  "While full RU": {
    "prefix": "пока",
    "body": ["Пока ${1:Условие} Цикл", "\t$0", "КонецЦикла;"],
    "description": "Цикл Пока (полное слово)"
  },
  "Try full RU": {
    "prefix": "попытка",
    "body": [
      "Попытка",
      "\t${1:Код}",
      "Исключение",
      "\tОписаниеОшибки = ОписаниеОшибки();",
      "\t$0",
      "КонецПопытки;"
    ],
    "description": "Попытка / Исключение (полное слово)"
  },
  "Region full RU": {
    "prefix": "область",
    "body": ["#Область ${1:ИмяОбласти}", "$0", "#КонецОбласти"],
    "description": "Область кода (полное слово)"
  },
  "Var full RU": {
    "prefix": "перем",
    "body": ["Перем ${1:ИмяПеременной};"],
    "description": "Объявление переменной (полное слово)"
  },
  "Procedure Export": {
    "prefix": "процедураэ",
    "body": [
      "Процедура ${1:ИмяПроцедуры}(${2:Параметры}) Экспорт",
      "\t$0",
      "КонецПроцедуры"
    ],
    "description": "Процедура Экспорт"
  },
  "Function Export": {
    "prefix": "функцияэ",
    "body": [
      "Функция ${1:ИмяФункции}(${2:Параметры}) Экспорт",
      "\t$0",
      "\tВозврат ${3:Результат};",
      "КонецФункции"
    ],
    "description": "Функция Экспорт"
  }
}
