; =============================================================================
; 1C BSL — Auto-indentation rules for Zed
; Version: 0.0.3
; Based on: tree-sitter-bsl grammar (alkoleft, rev 5152121)
; =============================================================================

; -----------------------------------------------------------------------------
; 1. ПРОЦЕДУРЫ И ФУНКЦИИ
; Процедура ... КонецПроцедуры / Функция ... КонецФункции
; -----------------------------------------------------------------------------
(procedure_definition
  (ENDPROCEDURE_KEYWORD) @end) @indent

(function_definition
  (ENDFUNCTION_KEYWORD) @end) @indent

; -----------------------------------------------------------------------------
; 2. УСЛОВИЯ
; Если ... Тогда ... КонецЕсли
; -----------------------------------------------------------------------------
(if_statement
  (ENDIF_KEYWORD) @end) @indent

; Иначе / ИначеЕсли — возврат на уровень открывающего Если
(else_clause
  (ELSE_KEYWORD) @end) @indent

(elseif_clause
  (ELSIF_KEYWORD) @end) @indent

; -----------------------------------------------------------------------------
; 3. ЦИКЛЫ
; Для ... Цикл ... КонецЦикла
; Пока ... Цикл ... КонецЦикла
; Для каждого ... Из ... Цикл ... КонецЦикла
; -----------------------------------------------------------------------------
(for_statement
  (ENDDO_KEYWORD) @end) @indent

(for_each_statement
  (ENDDO_KEYWORD) @end) @indent

(while_statement
  (ENDDO_KEYWORD) @end) @indent

; -----------------------------------------------------------------------------
; 4. ИСКЛЮЧЕНИЯ
; Попытка ... Исключение ... КонецПопытки
; -----------------------------------------------------------------------------
(try_statement
  (ENDTRY_KEYWORD) @end) @indent

; -----------------------------------------------------------------------------
; 5. ПРЕПРОЦЕССОР
; #Область ... #КонецОбласти
; #Если ... #КонецЕсли
; -----------------------------------------------------------------------------
; Все содержимое preprocessor получает +1 отступ
(preprocessor) @indent
; Конец области возвращает отступ на уровень выше
(PREPROC_ENDREGION_KEYWORD) @end
(PREPROC_ENDIF_KEYWORD) @end

; -----------------------------------------------------------------------------
; 6. СКОБКИ И МНОГОСТРОЧНЫЕ ВЫРАЖЕНИЯ
; Отступ для выражений в скобках, разнесённых на несколько строк
; -----------------------------------------------------------------------------
(parenthesized_expression
  ")" @end) @indent
