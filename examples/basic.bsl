#Область Пример

&НаКлиенте
Процедура Приветствие(Знач Имя) Экспорт
    Если Имя = Неопределено Тогда
        Сообщить("Привет, мир!");
        Возврат;
    ИначеЕсли Имя = "Admin" Тогда
        Сообщить("Привет, администратор!");
    Иначе
        Сообщить("Привет, " + Имя);
    КонецЕсли;

    // Многострочное выражение в скобках
    Результат = Новый Структура(
        "Ключ1", Значение1,
        "Ключ2", Значение2
    );
КонецПроцедуры

Функция ПолучитьЗапрос() Экспорт
    Запрос = Новый Запрос;
    Запрос.Текст = "ВЫБРАТЬ
        |   Номенклатура.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.Номенклатура КАК Номенклатура
        |ГДЕ
        |   Номенклатура.ПометкаУдаления = ЛОЖЬ";

    Возврат Запрос;
КонецФункции

Процедура ОбработкаДанных()
    Попытка
        Данные = ПолучитьДанные();
    Исключение
        Сообщить("Ошибка: " + ОписаниеОшибки());
    КонецПопытки;

    Для Сч = 1 По 10 Цикл
        Обработать(Сч);
    КонецЦикла;

    Пока НЕ Готово() Цикл
        Ждать(1);
    КонецЦикла;
КонецПроцедуры

#Область Вложенная
Процедура Тест()
    Перем Локальная;
    Локальная = Истина;
КонецПроцедуры
#КонецОбласти

